# Copy this file to .env.local for local development.
# Set the same variables in Vercel → Project → Settings → Environment Variables.

# ---- Auth.js (Google sign-in) ----
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ---- App auth (master password + session JWT) ----
APP_PASSWORD=
JWT_SECRET=
GATE_TTL_MINUTES=15
SESSION_TTL_MINUTES=10080
PRESIGN_TTL_SECONDS=3600

# ---- Cloudflare R2 ----
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# ---- Database (Postgres) ----
# Option A: full connection string
DATABASE_URL=
# Option B: built automatically from project id + password
SUPABASE_PROJECT_ID=
SUPABASE_DB_PASSWORD=

# ---- OpenAI (optional — chat assistant + auto-tagging) ----
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---- Visual indexing (optional) ----
# VISUAL_INDEX_BATCH=40
# VISUAL_INDEX_LOCAL=0
# HF_TOKEN=
# TRANSFORMERS_CACHE=.cache/transformers
