# Copy this file to .env.local for local development.
# Set the same variables in Vercel → Project → Settings → Environment Variables.

# ---- Auth.js (Google sign-in) ----
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ---- App auth (master password + session JWT) ----
APP_PASSWORD=
JWT_SECRET=
GATE_TTL_MINUTES=15
SESSION_TTL_MINUTES=10080
PRESIGN_TTL_SECONDS=3600

# ---- Cloudflare R2 ----
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# ---- Database (Postgres / Supabase) ----
# RECOMMENDED for Vercel: copy "Transaction pooler" URI from
# Supabase → Project → Connect → ORMs → Prisma → Transaction pooler
# Example: postgresql://postgres.[ref]:[password]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Alternative: pooler host + password (if you don't paste the full URI)
# SUPABASE_DB_HOST=aws-0-eu-west-1.pooler.supabase.com
# SUPABASE_DB_PORT=6543
# SUPABASE_DB_USER=postgres.kwhoeysmbcwtmqezoyzw
# SUPABASE_DB_PASSWORD=
# SUPABASE_DB_NAME=postgres

# Local dev fallback (direct connection — may not resolve on Vercel)
# SUPABASE_PROJECT_ID=
# SUPABASE_DB_PASSWORD=

# ---- OpenAI (optional — chat assistant + auto-tagging) ----
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---- Visual indexing (optional) ----
# VISUAL_INDEX_BATCH=40
# VISUAL_INDEX_LOCAL=0
# HF_TOKEN=
# TRANSFORMERS_CACHE=.cache/transformers
