# Copy this file to .env.local for local development.
# Set the same variables in Vercel → Project → Settings → Environment Variables.

# ---- Auth.js (Google sign-in) ----
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ---- App auth (master password + session JWT) ----
APP_PASSWORD=
JWT_SECRET=
GATE_TTL_MINUTES=15
SESSION_TTL_MINUTES=10080
PRESIGN_TTL_SECONDS=3600

# ---- Cloudflare R2 ----
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# ---- Database (Postgres / Supabase) ----
# On Vercel: either paste the full Transaction pooler URI below, OR leave it empty
# and set SUPABASE_PROJECT_ID + SUPABASE_DB_PASSWORD (recommended if URI keeps failing).
#
# If using DATABASE_URL it MUST be the full URI (not just the password):
# postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
# Encode special chars in the password (# → %23, @ → %40). No quotes around the value.
DATABASE_URL=

SUPABASE_PROJECT_ID=
SUPABASE_DB_PASSWORD=

# For Vercel production, prefer pooler host (IPv4) over direct db.*.supabase.co:
# SUPABASE_DB_HOST=aws-0-eu-west-1.pooler.supabase.com
# SUPABASE_DB_PORT=6543
# SUPABASE_DB_USER=postgres.YOUR_PROJECT_REF

# ---- OpenAI (optional — chat assistant + auto-tagging) ----
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---- Visual indexing (optional) ----
# VISUAL_INDEX_BATCH=40
# VISUAL_INDEX_LOCAL=0
# HF_TOKEN=
# TRANSFORMERS_CACHE=.cache/transformers
